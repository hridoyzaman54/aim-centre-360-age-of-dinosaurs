{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel_static",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["build/server/**"]
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
